---
---

<section class="relative pt-28 pb-12 sm:pt-32 sm:pb-20 lg:pt-40 lg:pb-28 overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Gradient Mesh / Orbs -->
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-brand-start/20 blur-[120px] animate-float delay-100"></div>
    <div class="absolute top-[20%] right-[-10%] w-[35%] h-[35%] rounded-full bg-brand-end/20 blur-[100px] animate-float delay-300"></div>
    <div class="absolute bottom-[-10%] left-[20%] w-[30%] h-[30%] rounded-full bg-brand-mid/15 blur-[80px] animate-float delay-500"></div>
    
    <!-- Grid overlay for subtle texture -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] dark:bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_80%)]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-mid/30 bg-brand-mid/10 text-brand-mid text-xs sm:text-sm font-semibold mb-6 sm:mb-8 animate-slide-up">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-mid opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-mid"></span>
      </span>
      #1 Free Instagram Downloader Online
    </div>

    <!-- Headline — Primary keyword in H1 -->
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold tracking-tight mb-6 animate-slide-up delay-100">
      Instagram Downloader<br class="hidden sm:block" />
      <span class="gradient-text">Free, Fast & HD</span>
    </h1>

    <!-- Subtitle with supporting keywords -->
    <p class="max-w-2xl mx-auto text-base sm:text-xl text-text-secondary mb-10 sm:mb-12 animate-slide-up delay-200">
      Download Instagram videos, reels, and photos in HD &amp; 4K — no watermark, no login, no app. The best <strong>Instagram reel downloader</strong> &amp; <strong>Instagram video downloader online</strong> — 100% free.
    </p>

    <!-- Download Input Component Placeholder -->
    <div class="max-w-3xl mx-auto animate-slide-up delay-300">
      <slot />
    </div>

    <!-- Stats / Trust Indicators -->
    <div class="mt-12 sm:mt-16 flex flex-wrap justify-center gap-6 sm:gap-8 text-sm text-text-muted font-medium animate-slide-up delay-400">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        No Watermark
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        No Login Required
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        HD &amp; 4K Quality
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        100% Free Forever
      </div>
    </div>
  </div>
</section>
