---
const faqs = [
  {
    q: "Is it legal to download Instagram videos and photos?",
    a: "Yes, it is perfectly legal to download Instagram content for personal use. However, you should not use downloaded content for commercial purposes or claim it as your own without permission from the original creator."
  },
  {
    q: "Do I need to install any software to use InstaDownloader?",
    a: "No! InstaDownloader is a web-based tool. You don't need to install any software, apps, or browser extensions. It works perfectly in any web browser on your phone, tablet, or computer."
  },
  {
    q: "Are there any download limits?",
    a: "No, there are absolutely no limits. You can download as many videos, reels, and photos as you want, completely free of charge."
  },
  {
    q: "Can I download content from private Instagram accounts?",
    a: "No. InstaDownloader can only download content from public Instagram accounts. We respect user privacy and Instagram's security policies, so private content remains inaccessible."
  },
  {
    q: "Where are the downloaded files saved on my device?",
    a: "When you download a file, it is saved to your browser's default download location. On mobile devices, this is usually the 'Downloads' folder or your camera roll/gallery. On PC/Mac, it's typically the 'Downloads' folder."
  },
  {
    q: "Will the downloaded videos have a watermark?",
    a: "No, all videos and photos downloaded through our tool are completely watermark-free and in their original quality."
  }
];

// Generate Schema.org JSON-LD for FAQ
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<section id="faq" class="py-24 relative">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Frequently Asked Questions</h2>
      <p class="text-text-secondary text-lg">Got questions? We've got answers.</p>
    </div>

    <!-- Inject Schema.org JSON -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <div class="space-y-4">
      {faqs.map((faq, i) => (
        <div class="faq-item glass-card overflow-hidden transition-all duration-300">
          <button 
            class="faq-button w-full px-6 py-5 text-left flex justify-between items-center gap-4 focus:outline-none focus-visible:bg-surface-alt"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
          >
            <span class="font-semibold text-lg text-text-primary">{faq.q}</span>
            <span class="faq-icon text-brand-mid transition-transform duration-300 shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </span>
          </button>
          
          <div 
            id={`faq-answer-${i}`} 
            class="faq-answer grid grid-rows-[0fr] transition-all duration-300"
          >
            <div class="overflow-hidden">
              <p class="px-6 pb-6 text-text-secondary leading-relaxed">
                {faq.a}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function setupFAQs() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const button = item.querySelector('.faq-button');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      
      if (!button || !answer || !icon) return;
      
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        // Close all other FAQs first (Accordion behavior)
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            const otherButton = otherItem.querySelector('.faq-button');
            const otherAnswer = otherItem.querySelector('.faq-answer');
            const otherIcon = otherItem.querySelector('.faq-icon');
            
            if (otherButton && otherAnswer && otherIcon) {
              otherButton.setAttribute('aria-expanded', 'false');
              otherAnswer.classList.remove('grid-rows-[1fr]');
              otherAnswer.classList.add('grid-rows-[0fr]');
              otherIcon.style.transform = 'rotate(0deg)';
              otherItem.classList.remove('border-brand-mid/30', 'bg-surface-alt/50');
            }
          }
        });
        
        // Toggle current FAQ
        if (isExpanded) {
          button.setAttribute('aria-expanded', 'false');
          answer.classList.remove('grid-rows-[1fr]');
          answer.classList.add('grid-rows-[0fr]');
          icon.style.transform = 'rotate(0deg)';
          item.classList.remove('border-brand-mid/30', 'bg-surface-alt/50');
        } else {
          button.setAttribute('aria-expanded', 'true');
          answer.classList.remove('grid-rows-[0fr]');
          answer.classList.add('grid-rows-[1fr]');
          icon.style.transform = 'rotate(45deg)';
          item.classList.add('border-brand-mid/30', 'bg-surface-alt/50');
        }
      });
    });
  }

  // Initialize
  setupFAQs();
</script>
