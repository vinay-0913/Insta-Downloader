---
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20" aria-labelledby="pages-heading">
  <div class="text-center mb-12">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card text-sm font-medium text-text-secondary mb-5">
      <svg class="w-4 h-4" style="color: var(--color-brand-mid)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      Learn more
    </div>
    <h2 id="pages-heading" class="text-3xl sm:text-4xl font-extrabold text-text-primary mb-4">
      Explore <span class="gradient-text">InstaDownloader</span>
    </h2>
    <p class="text-text-secondary max-w-xl mx-auto">
      Everything you need to know about our service — from who we are to how we protect your privacy.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- About Us -->
    <a href="/about" id="page-link-about" class="group glass-card p-6 hover:glass-card-hover transition-all duration-300 block" aria-label="About Us">
      <div class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
        style="background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.25)">
        <svg class="w-6 h-6" style="color: #a855f7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h3 class="text-base font-bold text-text-primary mb-2 group-hover:text-brand-mid transition-colors">About Us</h3>
      <p class="text-sm text-text-secondary leading-relaxed mb-4">Learn about our mission, values, and why we built InstaDownloader.</p>
      <span class="inline-flex items-center gap-1 text-xs font-semibold" style="color: #a855f7">
        Read more
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </a>

    <!-- Privacy Policy -->
    <a href="/privacy-policy" id="page-link-privacy" class="group glass-card p-6 hover:glass-card-hover transition-all duration-300 block" aria-label="Privacy Policy">
      <div class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
        style="background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.25)">
        <svg class="w-6 h-6" style="color: #22c55e" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h3 class="text-base font-bold text-text-primary mb-2 group-hover:text-brand-mid transition-colors">Privacy Policy</h3>
      <p class="text-sm text-text-secondary leading-relaxed mb-4">We don't track you. Read exactly what data we collect and why.</p>
      <span class="inline-flex items-center gap-1 text-xs font-semibold" style="color: #22c55e">
        Read more
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </a>

    <!-- Terms & Conditions -->
    <a href="/terms" id="page-link-terms" class="group glass-card p-6 hover:glass-card-hover transition-all duration-300 block" aria-label="Terms and Conditions">
      <div class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
        style="background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25)">
        <svg class="w-6 h-6" style="color: #f59e0b" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h3 class="text-base font-bold text-text-primary mb-2 group-hover:text-brand-mid transition-colors">Terms &amp; Conditions</h3>
      <p class="text-sm text-text-secondary leading-relaxed mb-4">Understand the terms of use and your responsibilities when using our service.</p>
      <span class="inline-flex items-center gap-1 text-xs font-semibold" style="color: #f59e0b">
        Read more
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </a>

    <!-- Contact Us -->
    <a href="/contact" id="page-link-contact" class="group glass-card p-6 hover:glass-card-hover transition-all duration-300 block" aria-label="Contact Us">
      <div class="w-12 h-12 rounded-xl mb-5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
        style="background: rgba(224,64,160,0.12); border: 1px solid rgba(224,64,160,0.25)">
        <svg class="w-6 h-6" style="color: #e040a0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </div>
      <h3 class="text-base font-bold text-text-primary mb-2 group-hover:text-brand-mid transition-colors">Contact Us</h3>
      <p class="text-sm text-text-secondary leading-relaxed mb-4">Got a question or found a bug? Send us a message and we'll reply within 48 hours.</p>
      <span class="inline-flex items-center gap-1 text-xs font-semibold" style="color: #e040a0">
        Get in touch
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  </div>
</section>
