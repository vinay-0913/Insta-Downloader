---
const features = [
  {
    title: 'No Login Required',
    desc: 'Our Instagram downloader never asks for your Instagram credentials. Your account stays 100% safe — no login, no password, no risk.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`
  },
  {
    title: 'HD & 4K Quality',
    desc: 'Download Instagram videos and reels in the highest resolution available — up to 4K HD quality. Our instagram video downloader hd never compresses your files.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`
  },
  {
    title: 'Lightning Fast Downloads',
    desc: 'Our servers connect directly to Instagram\'s CDN for instant, high-speed downloads. No waiting, no buffering — just fast, reliable media delivery.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  },
  {
    title: 'All Devices Supported',
    desc: 'Our online Instagram downloader works on iPhone, Android, Windows, Mac, and tablets. No app needed — just open your browser and download.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`
  },
  {
    title: 'Completely Free',
    desc: 'InstaDownloader is a 100% free instagram video downloader — no hidden fees, no premium plans, no limits on downloads. Use it as often as you like.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`
  },
  {
    title: 'No Watermark',
    desc: 'Every reel, video, and photo downloaded via InstaDownloader is completely watermark-free — you get the original file exactly as it appears on Instagram.',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.956 11.956 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`
  }
];
---

<section class="py-24 bg-surface-alt/50 border-y border-border/30">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Why Choose InstaDownloader?</h2>
      <p class="text-text-secondary text-lg">The most reliable free Instagram video downloader — trusted for fast, HD, watermark-free downloads of reels, videos &amp; photos.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(feature => (
        <div class="glass-card p-6 sm:p-8 group hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-brand-mid/10 text-brand-mid flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-brand-mid group-hover:text-white transition-all duration-300">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-xl font-bold mb-3 text-text-primary">{feature.title}</h3>
          <p class="text-text-secondary leading-relaxed">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
