---
const formats = [
  {
    title: 'Instagram Video Downloader',
    desc: 'Download high-quality Instagram videos (MP4) from any public post. Our free instagram video downloader HD supports up to 4K resolution — fast, secure, and no watermark.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>`,
    color: 'from-pink-500 to-rose-500'
  },
  {
    title: 'Instagram Photo Downloader',
    desc: 'Save single photos or full carousel albums in original HD resolution. The best insta post downloader for photos — works on all devices, completely free.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    color: 'from-purple-500 to-indigo-500'
  },
  {
    title: 'Instagram Reel Downloader',
    desc: 'Download Instagram Reels in HD & 4K with audio intact and zero watermark. The fastest free reel downloader online — no login, no app, no limits.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" /></svg>`,
    color: 'from-brand-start to-brand-mid'
  }
];
---

<section id="features" class="py-16 sm:py-20 bg-surface-alt/50 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">All-in-One <span class="gradient-text">Instagram Downloader</span></h2>
      <p class="text-text-secondary text-lg">Download Instagram videos, reels, and photos in the highest quality available — all from one free online tool.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {formats.map((format, index) => (
        <div class={`glass-card p-6 flex flex-col items-start group hover:-translate-y-2 hover:shadow-card-hover transition-all duration-300 border border-border hover:border-brand-mid/30 delay-${(index + 1) * 100}`}>
          <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${format.color} flex items-center justify-center text-white mb-6 shadow-lg group-hover:scale-110 transition-transform duration-300`}>
            <Fragment set:html={format.icon} />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-brand-mid transition-colors">{format.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{format.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
