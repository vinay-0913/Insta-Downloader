---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-alt/80 border-t border-border mt-16 sm:mt-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 sm:py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 sm:gap-12 md:gap-8">
      
      <!-- Brand & Info -->
      <div class="md:col-span-2 space-y-6">
        <a href="/" class="flex items-center gap-2.5 inline-block group" aria-label="InstaDownloader Home">
          <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </div>
          <span class="text-xl font-bold">
            <span class="gradient-text">Insta</span><span class="text-text-primary">Downloader</span>
          </span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed max-w-md">
          The #1 free <strong>Instagram downloader</strong> online. Save Instagram videos, reels, and photos in HD &amp; 4K quality — no watermark, no login, completely free.
        </p>
        <p class="text-xs text-text-muted">
          Disclaimer: This website is not affiliated with Instagram or Meta. All downloaded content belongs to its respective owners. We do not host any downloaded media on our servers.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-text-primary mb-4">Quick Links</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Instagram Downloader</a></li>
          <li><a href="#features" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Reel Downloader</a></li>
          <li><a href="#features" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Video Downloader</a></li>
          <li><a href="#how-it-works" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">How it Works</a></li>
          <li><a href="#faq" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-bold text-text-primary mb-4">Company</h4>
        <ul class="space-y-3">
          <li><a href="/about" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">About Us</a></li>
          <li><a href="/privacy-policy" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Terms of Service</a></li>
          <li><a href="/contact" class="text-sm text-text-secondary hover:text-brand-mid transition-colors">Contact Us</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 sm:mt-12 pt-6 sm:pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center gap-4 sm:gap-6">
      <p class="text-sm text-text-muted">
        &copy; {currentYear} InstaDownloader. All rights reserved.
      </p>
      
      <!-- Socials Placeholder -->
      <div class="flex items-center gap-4">
        <a href="#" class="w-8 h-8 rounded-full bg-surface-card flex items-center justify-center text-text-muted hover:text-brand-mid hover:bg-surface-card-hover transition-all border border-border" aria-label="Twitter">
