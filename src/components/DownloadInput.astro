---

---

<div
  class="glass-card p-2 sm:p-3 relative group focus-within:shadow-glow transition-all duration-300"
>
  <form
    id="download-form"
    class="flex flex-col sm:flex-row gap-2 relative z-10"
    onsubmit="event.preventDefault();"
  >
    <!-- Input wrapper -->
    <div
      class="relative flex-1 flex items-center bg-surface-alt border border-border rounded-xl transition-colors focus-within:border-brand-mid focus-within:bg-surface"
    >
      <!-- Icon -->
      <div class="pl-4 pr-2 text-text-muted">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
          ></path>
        </svg>
      </div>

      <!-- Actual Input -->
      <input
        type="url"
        id="url-input"
        class="w-full bg-transparent border-none py-3 sm:py-4 pr-24 text-base text-text-primary placeholder:text-sm sm:placeholder:text-base placeholder:text-text-muted focus:outline-none focus:ring-0"
        placeholder="Paste Instagram URL here..."
        required
        autocomplete="off"
      />

      <!-- Clear/Paste Buttons -->
      <div class="absolute right-2 flex items-center gap-1">
        <button
          type="button"
          id="clear-btn"
          class="hidden p-1.5 text-text-muted hover:text-error hover:bg-error/10 rounded-lg transition-colors cursor-pointer"
          aria-label="Clear input"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
        <button
          type="button"
          id="paste-btn"
          class="flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-text-secondary hover:text-brand-mid hover:bg-brand-mid/10 rounded-lg transition-colors cursor-pointer border border-border/50 whitespace-nowrap"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            ></path>
          </svg>
          Paste
        </button>
      </div>
    </div>

    <!-- Download Button -->
    <button
      type="submit"
      id="download-btn"
      class="gradient-bg text-white font-semibold py-3 sm:py-4 px-6 sm:px-8 rounded-xl hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer relative overflow-hidden group/btn shadow-md min-w-[140px] sm:min-w-[160px]"
    >
      <span id="btn-text">Download</span>
      <svg
        id="btn-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
        ></path>
      </svg>
      <!-- Loading spinner -->
      <svg
        id="btn-spinner"
        class="animate-spin h-5 w-5 text-white hidden"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </button>
  </form>

  <!-- Error/Status Message Area -->
  <div
    id="status-message"
    class="hidden mt-3 text-center text-sm font-medium transition-all duration-300 px-4"
  >
  </div>

  <!-- Result Area (populated dynamically) -->
  <div
    id="result-area"
    class="hidden mt-4 border-t border-border/50 pt-4 animate-fade-in"
  >
  </div>
</div>

<script>
  function setupDownloadInput() {
    const input = document.getElementById("url-input") as HTMLInputElement;
    const clearBtn = document.getElementById("clear-btn");
    const pasteBtn = document.getElementById("paste-btn");
    const form = document.getElementById("download-form");
    const btnText = document.getElementById("btn-text");
    const btnIcon = document.getElementById("btn-icon");
    const btnSpinner = document.getElementById("btn-spinner");
    const downloadBtn = document.getElementById(
      "download-btn",
    ) as HTMLButtonElement;
    const statusMsg = document.getElementById("status-message");
    const resultArea = document.getElementById("result-area");

    if (!input || !form) return;

    // Set initial state
    if (input.value.length > 0) {
      clearBtn?.classList.remove("hidden");
      pasteBtn?.classList.add("hidden");
      pasteBtn?.classList.remove("flex");
    } else {
      clearBtn?.classList.add("hidden");
      pasteBtn?.classList.remove("hidden");
      pasteBtn?.classList.add("flex");
    }

    // Toggle clear/paste buttons based on input value
    input.addEventListener("input", () => {
      if (input.value.length > 0) {
        clearBtn?.classList.remove("hidden");
        pasteBtn?.classList.add("hidden");
        pasteBtn?.classList.remove("flex");
        if (statusMsg) statusMsg.classList.add("hidden");
      } else {
        clearBtn?.classList.add("hidden");
        pasteBtn?.classList.remove("hidden");
        pasteBtn?.classList.add("flex");
      }
    });

    // Clear button
    clearBtn?.addEventListener("click", () => {
      input.value = "";
      input.focus();
      clearBtn.classList.add("hidden");
      pasteBtn?.classList.remove("hidden");
      pasteBtn?.classList.add("flex");
      resultArea!.classList.add("hidden");
      resultArea!.innerHTML = "";
      statusMsg?.classList.add("hidden");
    });

    // Paste button
    pasteBtn?.addEventListener("click", async () => {
      try {
        const text = await navigator.clipboard.readText();
        input.value = text;
        input.dispatchEvent(new Event("input"));
      } catch {
        showStatus("Failed to read clipboard. Please paste manually.", "error");
      }
    });

    // Show status helper
    const showStatus = (msg: string, type: "error" | "success" | "info") => {
      if (!statusMsg) return;
      statusMsg.textContent = msg;
      const colorClass =
        type === "error"
          ? "text-error"
          : type === "success"
            ? "text-success"
            : "text-brand-mid";
      statusMsg.className = `mt-3 text-center text-sm font-medium transition-all duration-300 px-4 ${colorClass}`;
      statusMsg.classList.remove("hidden");
    };

    // Set loading state
    const setLoading = (loading: boolean) => {
      if (loading) {
        if (btnText) btnText.textContent = "Processing...";
        btnIcon?.classList.add("hidden");
        btnSpinner?.classList.remove("hidden");
        downloadBtn.disabled = true;
        downloadBtn.classList.add("opacity-70");
      } else {
        if (btnText) btnText.textContent = "Download";
        btnIcon?.classList.remove("hidden");
        btnSpinner?.classList.add("hidden");
        downloadBtn.disabled = false;
        downloadBtn.classList.remove("opacity-70");
      }
    };

    // Helper to get a content type label
    const getTypeLabel = (type: string): string => {
      switch (type) {
        case "video":
          return "🎬 Video";
        case "reel":
          return "🎬 Reel";
        case "image":
          return "📸 Photo";
        case "carousel":
          return "📸 Carousel";
        case "story":
          return "📖 Story";
        default:
          return "📎 Media";
      }
    };

    // Render result
    const renderResult = (data: any) => {
      if (!resultArea) return;

      const mediaItems = data.media;
      const isSingle = mediaItems.length === 1;

      let html = `<div class="space-y-4">`;

      // Caption & Author
      if (data.caption || data.author) {
        html += `<div class="mb-2">`;
        if (data.author) {
          html += `<p class="text-sm text-text-muted mb-1">${data.author}</p>`;
        }
        if (data.caption) {
          html += `<p class="text-sm text-text-secondary line-clamp-2">${escapeHtml(data.caption)}</p>`;
        }
        html += `</div>`;
      }

      // Media items
      mediaItems.forEach((item: any, index: number) => {
        const isVideo = item.type === "video";
        const typeLabel = isVideo ? "Video" : "Photo";
        const quality = item.quality || (isVideo ? "HD" : "Original");
        const itemLabel = isSingle ? "" : ` #${index + 1}`;

        html += `
          <div class="flex flex-row items-center gap-3 sm:gap-4 p-3 sm:p-4 bg-surface-alt/50 rounded-xl border border-border/50">
            <!-- Thumbnail -->
            <div class="w-20 sm:w-28 aspect-square rounded-lg overflow-hidden bg-surface-alt border border-border shrink-0">
              <img 
                src="${item.thumbnail || item.url}" 
                alt="Preview${itemLabel}" 
                class="w-full h-full object-cover"
                onerror="this.parentElement.innerHTML='<div class=\\'flex items-center justify-center h-full text-text-muted text-xs\\'>${getTypeLabel(item.type)}</div>'"
              />
            </div>
            
            <!-- Info & Download -->
            <div class="flex-1 flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-3">
              <div class="flex-1">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] sm:text-xs font-semibold bg-brand-mid/10 text-brand-mid mb-1">
                  ${getTypeLabel(item.type)}${itemLabel}
                </span>
                <p class="text-[10px] sm:text-xs text-text-muted mt-0.5 sm:mt-1">
                  ${quality} Quality ${item.size ? `<span class="opacity-50 mx-1">•</span> ${item.size}` : ""}
                </p>
              </div>
              
              <a 
                href="/api/proxy?url=${encodeURIComponent(item.url)}" 
                target="_blank" 
                rel="noopener noreferrer"
                download
                class="gradient-bg text-white font-medium py-2 sm:py-2.5 px-4 sm:px-5 rounded-lg text-center text-xs sm:text-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-1.5 sm:gap-2 shadow-md whitespace-nowrap"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download ${quality}
              </a>
            </div>
          </div>
        `;
      });

      html += `</div>`;

      // Add download tip
      html += `
        <p class="text-xs text-text-muted text-center mt-4 flex items-center justify-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Tip: If the file opens in browser, right-click and select "Save as..." to download.
        </p>
      `;

      resultArea.innerHTML = html;
      resultArea.classList.remove("hidden");

      // Smooth scroll to result on mobile
      if (window.innerWidth < 640) {
        resultArea.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    };

    // Escape HTML to prevent XSS
    const escapeHtml = (str: string): string => {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    };

    // Form submission — calls real API
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const url = input.value.trim();

      // Client-side validation
      if (!url) {
        showStatus("Please enter an Instagram URL", "error");
        return;
      }

      if (!url.includes("instagram.com")) {
        showStatus(
          "Please enter a valid Instagram URL (e.g. instagram.com/p/...)",
          "error",
        );
        return;
      }

      // Start loading
      setLoading(true);
      statusMsg?.classList.add("hidden");
      resultArea?.classList.add("hidden");
      if (resultArea) resultArea.innerHTML = "";

      try {
        // Call the backend API
        const response = await fetch("/api/download", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url }),
        });

        const data = await response.json();

        if (data.success) {
          showStatus("✓ Content found! Click below to download.", "success");
          renderResult(data);
        } else {
          showStatus(
            data.error || "Failed to process this URL. Please try again.",
            "error",
          );
        }
      } catch (err: any) {
        showStatus(
          "Network error. Please check your connection and try again.",
          "error",
        );
        console.error("Download fetch error:", err);
      } finally {
        setLoading(false);
      }
    });
  }

  // Initialize
  setupDownloadInput();
</script>
