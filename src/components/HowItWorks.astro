---
const steps = [
  {
    number: '01',
    title: 'Copy the Instagram Link',
    desc: 'Open Instagram, find the video, reel, or photo you want to download, tap the three dots (⋯) menu, and select "Copy Link".'
  },
  {
    number: '02',
    title: 'Paste URL & Click Download',
    desc: 'Return to InstaDownloader, paste the copied Instagram URL into the box above, and click the Download button.'
  },
  {
    number: '03',
    title: 'Save to Your Device',
    desc: 'Choose your preferred quality (HD, 4K), then save the video, reel, or photo directly to your phone or computer — no watermark.'
  }
];
---

<section id="how-it-works" class="py-24 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">How to Download Instagram Videos & Reels</h2>
      <p class="text-text-secondary text-lg">Use our free online Instagram downloader in just 3 simple steps — no app, no login, no limits.</p>
    </div>

    <div class="relative">
      <!-- Connecting Line (Desktop) -->
      <div class="hidden md:block absolute top-12 left-[10%] right-[10%] h-0.5 bg-gradient-to-r from-transparent via-brand-mid/30 to-transparent"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative z-10">
        {steps.map((step, index) => (
          <div class="flex flex-col items-center text-center group">
            <!-- Number Badge -->
            <div class="w-24 h-24 rounded-full glass-card flex items-center justify-center mb-6 relative group-hover:-translate-y-2 transition-transform duration-300">
              <div class="absolute inset-2 rounded-full border-2 border-dashed border-brand-mid/30 animate-[spin-slow_10s_linear_infinite]"></div>
              <span class="text-3xl font-black gradient-text">{step.number}</span>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold mb-3">{step.title}</h3>
            <p class="text-text-secondary">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
