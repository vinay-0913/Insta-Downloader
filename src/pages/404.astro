---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 — Page Not Found | InstaDownloader"
  description="Oops! The page you're looking for doesn't exist. Head back to InstaDownloader and start downloading Instagram videos, reels and photos for free."
>
  <Header />

  <main class="error-page">

    <!-- Ambient background blobs -->
    <div class="blobs" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>

    <!-- Floating particles -->
    <div class="particles" aria-hidden="true">
      {Array.from({ length: 10 }).map((_, i) => (
        <div
          class="particle"
          style={`--x: ${10 + i * 9}%; --delay: ${(i * 0.6).toFixed(1)}s; --dur: ${4.5 + (i % 4) * 0.8}s;`}
        ></div>
      ))}
    </div>

    <div class="error-card">

      <!-- 404 Badge -->
      <div class="badge-404" aria-hidden="true">404</div>

      <!-- Icon -->
      <div class="icon-wrap">
        <svg class="icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="error-heading">Page <span class="gradient-text">Not Found</span></h1>
      <p class="error-desc">
        Looks like this reel got deleted. The page you're looking for doesn't exist or has been moved.
      </p>

      <!-- Action buttons -->
      <div class="actions">
        <a href="/" id="back-home-btn" class="btn-primary">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to Home
        </a>
        <a href="/contact" id="contact-404-btn" class="btn-secondary">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Report Broken Link
        </a>
      </div>

      <!-- Quick links -->
      <div class="quick-links glass-card">
        <p class="quick-links-label">You might be looking for</p>
        <div class="quick-links-grid">
          {[
            { label: "Instagram Downloader", href: "/", icon: "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" },
            { label: "About Us",             href: "/about",          icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
            { label: "Privacy Policy",       href: "/privacy-policy", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
            { label: "Contact Us",           href: "/contact",        icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
          ].map((link) => (
            <a href={link.href} class="quick-link-item group">
              <div class="quick-link-icon gradient-bg">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={link.icon} />
                </svg>
              </div>
              <span class="quick-link-text">{link.label}</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Page shell ─────────────────────────────────── */
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1rem 4rem;   /* top = header height (~5rem) + breathing room */
    position: relative;
    overflow: hidden;
  }

  /* ── Background blobs ───────────────────────────── */
  .blobs { position: absolute; inset: 0; pointer-events: none; }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    animation: blob-float 9s ease-in-out infinite;
  }
  .blob-1 {
    width: 420px; height: 420px;
    background: radial-gradient(circle, var(--color-brand-end), transparent 70%);
    opacity: 0.15;
    top: -8%; left: -8%;
  }
  .blob-2 {
    width: 340px; height: 340px;
    background: radial-gradient(circle, var(--color-brand-start), transparent 70%);
    opacity: 0.12;
    bottom: 0; right: -5%;
    animation-delay: -3s;
  }
  .blob-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, var(--color-brand-mid), transparent 70%);
    opacity: 0.1;
    top: 55%; left: 40%;
    animation-delay: -6s;
  }
  @keyframes blob-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(18px, -18px) scale(1.04); }
    66%       { transform: translate(-14px, 14px) scale(0.96); }
  }

  /* ── Floating particles ─────────────────────────── */
  .particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .particle {
    position: absolute;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-brand-mid);
    left: var(--x);
    bottom: -10px;
    opacity: 0;
    animation: rise var(--dur) var(--delay) ease-in-out infinite;
  }
  @keyframes rise {
    0%   { transform: translateY(0)   scale(0.5); opacity: 0; }
    15%  { opacity: 0.55; }
    85%  { opacity: 0.2; }
    100% { transform: translateY(-100vh) scale(1.4); opacity: 0; }
  }

  /* ── Central card ───────────────────────────────── */
  .error-card {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 560px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* ── 404 badge ──────────────────────────────────── */
  .badge-404 {
    font-size: clamp(3rem, 8vw, 5rem);   /* capped at 5rem ≈ 80px — readable but not dominant */
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--color-brand-start), var(--color-brand-mid), var(--color-brand-end));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: glitch 5s infinite;
    position: relative;
  }
  @keyframes glitch {
    0%, 88%, 100% { transform: none; filter: none; }
    90% { transform: skewX(-2deg) translateX(-3px); }
    92% { transform: skewX(2deg)  translateX(3px);  }
    94% { transform: skewX(-1deg) translateX(0);    }
    96% { transform: none; }
  }

  /* ── Icon ───────────────────────────────────────── */
  .icon-wrap {
    width: 3.75rem; height: 3.75rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, var(--color-brand-start), var(--color-brand-mid), var(--color-brand-end));
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 32px rgba(168,85,247,0.35);
    margin-bottom: 1rem;
    animation: float 4s ease-in-out infinite;
  }
  .icon-svg { width: 1.875rem; height: 1.875rem; color: #fff; }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  /* ── Text ───────────────────────────────────────── */
  .error-heading {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }
  .error-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 38ch;
    margin: 0 auto 1.25rem;
  }

  /* ── Action buttons ─────────────────────────────── */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--color-brand-start), var(--color-brand-mid), var(--color-brand-end));
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    box-shadow: 0 4px 20px rgba(168,85,247,0.3);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(168,85,247,0.4); }
  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    border-radius: 0.75rem;
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    font-weight: 600;
    font-size: 0.9rem;
    backdrop-filter: blur(12px);
    transition: transform 0.2s, background 0.2s;
    text-decoration: none;
  }
  .btn-secondary:hover { transform: translateY(-2px); background: var(--color-surface-card-hover); }

  /* ── Quick links ────────────────────────────────── */
  .quick-links {
    width: 100%;
    padding: 1.25rem 1.5rem;
    border-radius: 1.25rem;
  }
  .quick-links-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .quick-links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }
  @media (max-width: 480px) {
    .quick-links-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .quick-link-item {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    padding: 0.6rem 0.4rem;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .quick-link-item:hover { background: var(--color-surface-card); }
  .quick-link-icon {
    width: 2.25rem; height: 2.25rem;
    border-radius: 0.6rem;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s;
  }
  .quick-link-item:hover .quick-link-icon { transform: scale(1.1); }
  .quick-link-text {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-align: center;
    line-height: 1.3;
  }
</style>
