---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import DownloadInput from '../components/DownloadInput.astro';
import FormatCards from '../components/FormatCards.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import SeoContent from '../components/SeoContent.astro';
import FAQ from '../components/FAQ.astro';
import SitePages from '../components/SitePages.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Instagram Downloader — Download Instagram Videos, Reels & Photos Free"
  description="Free Instagram downloader to save Instagram videos, reels, photos & posts in HD & 4K quality. No watermark, no login, no app needed. The #1 online Instagram video downloader."
>
  <Header />
  
  <main>
    <Hero>
      <DownloadInput />
    </Hero>
    
    <FormatCards />
    <HowItWorks />
    <WhyChooseUs />
    <SeoContent />
    <FAQ />
    <SitePages />
  </main>
  
  <Footer />
</Layout>
